@model SistemaMatriculaCibertec.Models.Matricula

@{
    ViewBag.Title = "Nueva Matrícula";
}

<div class="page-container">

    <div class="card-custom">

        <div class="card-header-custom">
            <h3 class="mb-1">Nueva Matrícula</h3>
            <small class="text-muted">Registro de matrícula de alumno</small>
        </div>

        <div class="card-body-custom">

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="mb-3">
                    <label>Código de Matrícula</label>
                    @Html.EditorFor(model => model.CodigoMatricula, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.CodigoMatricula, "", new { @class = "text-danger" })
                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label>Alumno</label>
                        @Html.DropDownList("IdAlumno", null, "-- Seleccione alumno --", new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.IdAlumno, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Curso</label>
                        @Html.DropDownList("IdCurso", null, "-- Seleccione curso --", new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.IdCurso, "", new { @class = "text-danger" })
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label>Fecha de Matrícula</label>
                        @Html.EditorFor(model => model.FechaMatricula, new { htmlAttributes = new { @class = "form-control", type = "date" } })
                        @Html.ValidationMessageFor(model => model.FechaMatricula, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Estado</label>
                        @Html.EditorFor(model => model.Estado, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Estado, "", new { @class = "text-danger" })
                    </div>

                </div>

                <hr />

                <button type="submit" class="btn btn-danger btn-guardar">
                    Guardar
                </button>

                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    Volver
                </a>
            }

        </div>

    </div>

</div>