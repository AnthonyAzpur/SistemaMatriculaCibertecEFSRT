@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>Sistema Académico</title>


    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">



    <style>


        body {
            margin: 0;
            font-family: 'Segoe UI',Arial;
            background: #f4f7fb;
        }


        /* SIDEBAR */


        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 240px;
            height: 100vh;
            background: #102b4e;
            color: white;
            transition: .3s;
            z-index: 1000;
        }



            .sidebar.hide {
                left: -240px;
            }




        .logo {
            height: 75px;
            display: flex;
            align-items: center;
            padding: 15px;
            border-bottom: 1px solid #27405e;
        }



            .logo i {
                font-size: 35px;
                color: #4d91ff;
            }



            .logo h4 {
                margin-left: 10px;
                font-size: 18px;
            }




        .menu {
            padding-top: 20px;
        }




            .menu a {
                display: flex;
                align-items: center;
                gap: 15px;
                padding: 14px 20px;
                margin: 5px 10px;
                color: white;
                text-decoration: none;
                border-radius: 10px;
            }



                .menu a:hover {
                    background: #3478e5;
                }





        /* CONTENIDO */


        .main {
            margin-left: 240px;
            min-height: 100vh;
            transition: .3s;
        }



            .main.expand {
                margin-left: 0;
            }




        .header {
            height: 70px;
            background: white;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 30px;
            box-shadow: 0 2px 10px #ddd;
        }



        .content {
            padding: 25px;
        }




        .btn-menu {
            font-size: 22px;
        }





        /* CELULAR */


        @@media(max-width:768px) {



            .sidebar {
                left: -240px;
            }



                .sidebar.show {
                    left: 0;
                }




            .main {
                margin-left: 0;
            }
        }
    </style>


</head>



<body>




    <!-- MENU -->



    <div class="sidebar" id="sidebar">



        <div class="logo">


            <i class="bi bi-mortarboard-fill"></i>


            <h4>

                CIBERTEC

                <br>

                <small>Sistema</small>

            </h4>


        </div>



        <div class="menu">



            <a href="@Url.Action("Index","Alumnoes")">

                <i class="bi bi-people"></i>

                Alumnos

            </a>




            <a href="@Url.Action("Index","Cursoes")">

                <i class="bi bi-book"></i>

                Cursos

            </a>





            <a href="@Url.Action("Index","Matriculas")">

                <i class="bi bi-clipboard-check"></i>

                Matrículas

            </a>





            <a href="@Url.Action("Index","Retiroes")">

                <i class="bi bi-box-arrow-right"></i>

                Retiros

            </a>



            <a href="#">

                <i class="bi bi-search"></i>

                Consultas

            </a>




            <a href="#">

                <i class="bi bi-file-earmark-bar-graph"></i>

                Reportes

            </a>




        </div>



    </div>








    <!-- CONTENIDO -->



    <div class="main" id="main">



        <div class="header">



            <button class="btn btn-light btn-menu"
                    onclick="toggleMenu()">


                <i class="bi bi-list"></i>


            </button>




            <div>

                Sistema Académico

            </div>




            <div>


                <i class="bi bi-person-circle"></i>


                Administrador


            </div>




        </div>






        <div class="content">


            @RenderBody()


        </div>




    </div>






    <script>


        function toggleMenu() {


            var sidebar = document.getElementById("sidebar");

            var main = document.getElementById("main");



            // CELULAR

            if (window.innerWidth <= 768) {


                sidebar.classList.toggle("show");


            }
            else {


                // PC

                sidebar.classList.toggle("hide");

                main.classList.toggle("expand");


            }


        }




        // cerrar menú tocando fuera (solo celular)

        document.addEventListener("click", function (e) {



            if (window.innerWidth <= 768) {



                var sidebar = document.getElementById("sidebar");

                var boton = document.querySelector(".btn-menu");



                if (sidebar.classList.contains("show")) {


                    if (!sidebar.contains(e.target) &&
                        !boton.contains(e.target)) {



                        sidebar.classList.remove("show");


                    }


                }


            }



        });



    </script>



    <script src="~/Scripts/jquery-3.7.0.min.js"></script>

    <script src="~/Scripts/bootstrap.min.js"></script>


    @RenderSection("scripts", required: false)



</body>


</html>