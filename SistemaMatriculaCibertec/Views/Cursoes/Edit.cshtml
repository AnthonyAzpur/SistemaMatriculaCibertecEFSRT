@model SistemaMatriculaCibertec.Models.Curso

@{
    ViewBag.Title = "Editar Curso";
}

<style>
    .page-container {
        padding: 20px;
    }

    .card-custom {
        background: white;
        border-radius: 18px;
        box-shadow: 0 3px 12px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .card-header-custom {
        padding: 25px;
        border-bottom: 1px solid #eef2f7;
    }

    .card-body-custom {
        padding: 25px;
    }

    .form-control {
        border-radius: 10px;
        height: 45px;
    }

    textarea.form-control {
        height: 100px;
    }

    .btn-guardar {
        min-width: 140px;
    }
</style>

<div class="page-container">

    <div class="card-custom">

        <div class="card-header-custom">
            <h3 class="mb-1">Editar Curso</h3>
            <small class="text-muted">Actualizar información del curso</small>
        </div>

        <div class="card-body-custom">

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                @Html.HiddenFor(model => model.IdCurso)

                <div class="mb-3">
                    <label>Código del Curso</label>
                    @Html.EditorFor(model => model.CodigoCurso, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.CodigoCurso, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    <label>Nombre del Curso</label>
                    @Html.EditorFor(model => model.NombreCurso, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(model => model.NombreCurso, "", new { @class = "text-danger" })
                </div>

                <div class="row">

                    <div class="col-md-4 mb-3">
                        <label>Créditos</label>
                        @Html.EditorFor(model => model.Creditos, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Creditos, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Vacantes</label>
                        @Html.EditorFor(model => model.Vacantes, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Vacantes, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Estado</label>
                        @Html.EditorFor(model => model.Estado, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Estado, "", new { @class = "text-danger" })
                    </div>

                </div>

                <hr />

                <button type="submit" class="btn btn-primary btn-guardar">
                    Guardar cambios
                </button>

                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    Cancelar
                </a>
            }

        </div>

    </div>

</div>