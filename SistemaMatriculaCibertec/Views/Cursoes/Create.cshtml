@model SistemaMatriculaCibertec.Models.Curso

@{
    ViewBag.Title = "Nuevo Curso";
}

<div class="page-container">

    <div class="card-custom">

        <div class="card-header-custom">

            <h3 class="mb-1">Nuevo Curso</h3>

            <small class="text-muted">
                Registro de cursos académicos
            </small>

        </div>

        <div class="card-body-custom">

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label>Código del Curso</label>

                        @Html.EditorFor(model => model.CodigoCurso, new
                        {
                            htmlAttributes = new
                            {
                                @class = "form-control",
                                placeholder = "Ej: CUR-001"
                            }
                        })

                        @Html.ValidationMessageFor(model => model.CodigoCurso, "", new { @class = "text-danger" })

                    </div>

                    <div class="col-md-6 mb-3">

                        <label>Nombre del Curso</label>

                        @Html.EditorFor(model => model.NombreCurso, new
                        {
                            htmlAttributes = new
                            {
                                @class = "form-control",
                                placeholder = "Ej: Programación Web"
                            }
                        })

                        @Html.ValidationMessageFor(model => model.NombreCurso, "", new { @class = "text-danger" })

                    </div>

                </div>

                <div class="row">

                    <div class="col-md-4 mb-3">

                        <label>Créditos</label>

                        @Html.EditorFor(model => model.Creditos, new
                        {
                            htmlAttributes = new
                            {
                                @class = "form-control",
                                type = "number",
                                min = "0"
                            }
                        })

                        @Html.ValidationMessageFor(model => model.Creditos, "", new { @class = "text-danger" })

                    </div>

                    <div class="col-md-4 mb-3">

                        <label>Vacantes</label>

                        @Html.EditorFor(model => model.Vacantes, new
                        {
                            htmlAttributes = new
                            {
                                @class = "form-control",
                                type = "number",
                                min = "0"
                            }
                        })

                        @Html.ValidationMessageFor(model => model.Vacantes, "", new { @class = "text-danger" })

                    </div>

                    <div class="col-md-4 mb-3">

                        <label>Estado</label>

                        @Html.DropDownListFor(model => model.Estado,
                            new SelectList(new[]
                            {
                                new { Value = "Activo", Text = "Activo" },
                                new { Value = "Inactivo", Text = "Inactivo" }
                            }, "Value", "Text"),
                            "-- Seleccione --",
                            new { @class = "form-control" }
                        )

                        @Html.ValidationMessageFor(model => model.Estado, "", new { @class = "text-danger" })

                    </div>

                </div>

                <hr />

                <div class="d-flex gap-2">

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Guardar
                    </button>

                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Volver
                    </a>

                </div>
            }

        </div>

    </div>

</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}