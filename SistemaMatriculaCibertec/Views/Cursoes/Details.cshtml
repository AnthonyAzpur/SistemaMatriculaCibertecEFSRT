@model SistemaMatriculaCibertec.Models.Curso

@{
    ViewBag.Title = "Detalle Curso";
}

<style>
    .page-container {
        padding: 20px;
    }

    .card-custom {
        background: white;
        border-radius: 18px;
        box-shadow: 0 3px 12px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .card-header-custom {
        padding: 25px;
        border-bottom: 1px solid #eef2f7;
    }

    .card-body-custom {
        padding: 25px;
    }

    .info-box {
        background: #f8fafc;
        padding: 15px;
        border-radius: 12px;
        margin-bottom: 10px;
    }

    .label-title {
        font-weight: 600;
        color: #64748b;
        font-size: 13px;
    }

    .value-text {
        font-size: 15px;
        color: #0f172a;
        font-weight: 500;
    }

    .btn-group-custom {
        margin-top: 15px;
        display: flex;
        gap: 10px;
    }
</style>

<div class="page-container">

    <div class="card-custom">

        <div class="card-header-custom">
            <h3 class="mb-1">Detalle del Curso</h3>
            <small class="text-muted">Información completa del curso seleccionado</small>
        </div>

        <div class="card-body-custom">

            <div class="info-box">
                <div class="label-title">Código del Curso</div>
                <div class="value-text">@Model.CodigoCurso</div>
            </div>

            <div class="info-box">
                <div class="label-title">Nombre del Curso</div>
                <div class="value-text">@Model.NombreCurso</div>
            </div>

            <div class="info-box">
                <div class="label-title">Créditos</div>
                <div class="value-text">@Model.Creditos</div>
            </div>

            <div class="info-box">
                <div class="label-title">Vacantes</div>
                <div class="value-text">@Model.Vacantes</div>
            </div>

            <div class="info-box">
                <div class="label-title">Estado</div>
                <div class="value-text">@Model.Estado</div>
            </div>

            <hr />

            <div class="btn-group-custom">

                <a href="@Url.Action("Edit", new { id = Model.IdCurso })"
                   class="btn btn-primary">
                    Editar
                </a>

                <a href="@Url.Action("Index")"
                   class="btn btn-secondary">
                    Volver
                </a>

            </div>

        </div>

    </div>

</div>