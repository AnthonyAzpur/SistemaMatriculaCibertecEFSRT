@model IEnumerable<SistemaMatriculaCibertec.Models.Alumno>

@{
    ViewBag.Title = "Alumnos";
}

<style>

    body {
        background: #f4f7fb;
    }

    .page-container {
        padding: 20px;
    }

    .card-custom {
        background: white;
        border-radius: 18px;
        box-shadow: 0 3px 12px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .card-header-custom {
        padding: 25px;
        border-bottom: 1px solid #eef2f7;
    }

        .card-header-custom h3 {
            font-weight: 700;
            color: #0f172a;
        }

        .card-header-custom small {
            font-size: 14px;
        }

    .btn-primary {
        background: #2563eb;
        border-color: #2563eb;
        border-radius: 10px;
        padding: 10px 18px;
        font-weight: 500;
    }

        .btn-primary:hover {
            background: #1d4ed8;
            border-color: #1d4ed8;
        }

    .card-body-custom {
        padding: 20px 25px;
    }

    .search-box {
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 12px;
        background: #fff;
        border: 1px solid #e5eaf1;
        border-radius: 12px;
        padding: 0 16px;
        height: 52px;
    }

        .search-box i {
            color: #94a3b8;
            font-size: 18px;
        }

        .search-box input {
            border: none;
            outline: none;
            flex: 1;
            height: 100%;
            font-size: 14px;
        }

            .search-box input::placeholder {
                color: #b3bdcb;
            }

        .search-box .results-badge {
            background: #f1f5f9;
            color: #64748b;
            font-size: 12px;
            font-weight: 600;
            padding: 6px 12px;
            border-radius: 20px;
            white-space: nowrap;
        }

    .table thead {
        background: #f8fafc;
    }

    .table th {
        border: none;
        color: #64748b;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: .03em;
    }

    .table td {
        vertical-align: middle;
    }

        .table td strong.text-primary {
            color: #2563eb !important;
        }

    .badge-estado {
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        display: inline-block;
    }

    .badge-success-custom {
        background: #d1fae5;
        color: #065f46;
    }

    .badge-danger-custom {
        background: #fee2e2;
        color: #991b1b;
    }

    .btn-action {
        width: 32px;
        height: 32px;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        border-radius: 8px;
        background: transparent;
        border: none;
        font-size: 16px;
        transition: background .15s;
    }

        .btn-action:hover {
            background: #f1f5f9;
        }

    .pagination-custom {
        padding: 15px;
        display: flex;
        justify-content: flex-end;
        gap: 5px;
    }

        .pagination-custom a {
            width: 35px;
            height: 35px;
            border-radius: 8px;
            border: 1px solid #ddd;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            background: white;
            color: #333;
        }

        .pagination-custom .active {
            background: #2563eb;
            color: white;
            border-color: #2563eb;
        }

    /* ===== Modal Editar Alumno ===== */

    .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(15, 23, 42, .5);
        z-index: 1000;
        align-items: center;
        justify-content: center;
    }

        .modal-overlay.show {
            display: flex;
        }

    .modal-box {
        background: white;
        border-radius: 16px;
        width: 100%;
        max-width: 560px;
        margin: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,.2);
        max-height: 90vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .modal-header-custom {
        padding: 22px 25px;
        border-bottom: 1px solid #eef2f7;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .modal-header-custom h4 {
            margin: 0;
            font-weight: 700;
            color: #0f172a;
        }

        .modal-header-custom .btn-close-modal {
            background: none;
            border: none;
            font-size: 22px;
            color: #64748b;
            cursor: pointer;
            line-height: 1;
        }

    .modal-body-wrapper {
        padding: 25px;
        overflow-y: auto;
    }

    .modal-body-grid {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .form-row {
        display: flex;
        gap: 18px;
    }

        .form-row .form-col {
            flex: 1;
            min-width: 0;
        }

    .modal-label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: #334155;
        margin-bottom: 6px;
    }

    .modal-input {
        width: 100%;
        height: 46px;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 0 14px;
        font-size: 14px;
        background: #f8fafc;
        outline: none;
        box-sizing: border-box;
    }

        .modal-input:focus {
            border-color: #2563eb;
            background: #fff;
        }

    select.modal-select {
        background: #f8fafc;
        cursor: pointer;
    }

    .modal-footer-custom {
        padding: 18px 25px;
        border-top: 1px solid #eef2f7;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .btn-cancelar {
        background: white;
        border: 1px solid #e2e8f0;
        color: #334155;
        border-radius: 10px;
        padding: 10px 18px;
        font-weight: 500;
    }

        .btn-cancelar:hover {
            background: #f8fafc;
        }

    .btn-guardar {
        background: #2563eb;
        border: 1px solid #2563eb;
        color: white;
        border-radius: 10px;
        padding: 10px 18px;
        font-weight: 500;
    }

        .btn-guardar:hover {
            background: #1d4ed8;
        }
</style>

<div class="page-container">

    <div class="card-custom">

        <div class="card-header-custom">

            <div class="d-flex justify-content-between align-items-center">

                <div>

                    <h3 class="mb-1">
                        Módulo de Alumnos
                    </h3>

                    <small class="text-muted">
                        Gestión y registro de alumnos de la institución
                    </small>

                </div>

                <a href="javascript:void(0)"
                   class="btn btn-primary"
                   id="btnNuevoAlumno">

                    <i class="bi bi-plus-lg"></i> Nuevo Alumno

                </a>

            </div>

        </div>

        <div class="card-body-custom">

            <div class="search-box">

                <i class="bi bi-search"></i>

                <input type="text"
                       id="txtBuscar"
                       placeholder="Buscar por nombre, apellido, DNI o código..." />

                <span class="results-badge" id="lblResultados">
                    @Model.Count() resultados
                </span>

            </div>

            <div class="table-responsive">

                <table class="table table-hover"
                       id="tablaAlumnos">

                    <thead>

                        <tr>

                            <th>CÓDIGO</th>
                            <th>NOMBRES</th>
                            <th>APELLIDOS</th>
                            <th>DNI</th>
                            <th>CORREO</th>
                            <th>TELÉFONO</th>
                            <th>ESTADO</th>
                            <th>FECHA REGISTRO</th>
                            <th>ACCIONES</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    <strong class="text-primary">
                                        @item.CodigoAlumno
                                    </strong>
                                </td>

                                <td>@item.Nombres</td>

                                <td>@item.Apellidos</td>

                                <td>@item.DNI</td>

                                <td>@item.Correo</td>

                                <td>@item.Telefono</td>

                                <td>

                                    <span class="badge-estado @(item.Estado == "Activo" ? "badge-success-custom" : "badge-danger-custom")">
                                        @item.Estado
                                    </span>

                                </td>

                                <td>

                                    @(item.FechaRegistro.ToString("dd/MM/yyyy"))

                                </td>

                                <td>

                                    <a href="javascript:void(0)"
                                       class="btn btn-action btn-editar-alumno"
                                       data-id="@item.IdAlumno"
                                       data-codigo="@item.CodigoAlumno"
                                       data-nombres="@item.Nombres"
                                       data-apellidos="@item.Apellidos"
                                       data-dni="@item.DNI"
                                       data-telefono="@item.Telefono"
                                       data-correo="@item.Correo"
                                       data-estado="@item.Estado"
                                       data-fecharegistro="@item.FechaRegistro.ToString("yyyy-MM-ddTHH:mm:ss")">

                                        <i class="bi bi-pencil-fill" style="color:#2563eb;"></i>

                                    </a>

                                    <a href="javascript:void(0)"
                                       class="btn btn-action btn-eliminar-alumno"
                                       data-id="@item.IdAlumno"
                                       data-nombrecompleto="@item.Nombres @item.Apellidos"
                                       data-codigo="@item.CodigoAlumno">

                                        <i class="bi bi-trash-fill" style="color:#dc2626;"></i>

                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

        <div class="pagination-custom">

            <a href="#">‹</a>

            <a href="#" class="active">1</a>

            <a href="#">›</a>

        </div>

    </div>

</div>

<div class="modal-overlay" id="modalCrearAlumno">

    <div class="modal-box">

        <div class="modal-header-custom">
            <h4>Nuevo Alumno</h4>
            <button type="button" class="btn-close-modal" id="btnCerrarModalCrear">&times;</button>
        </div>

        @using (Html.BeginForm("Create", "Alumnoes", FormMethod.Post, new { id = "formCrearAlumno" }))
        {
            @Html.AntiForgeryToken()

            <div class="modal-body-wrapper">

                <div class="modal-body-grid">

                    <div class="form-row">

                        <div class="form-col">
                            <label class="modal-label">Código *</label>
                            <input type="text" name="CodigoAlumno" class="modal-input" required />
                        </div>

                        <div class="form-col">
                            <label class="modal-label">DNI *</label>
                            <input type="text" name="DNI" class="modal-input" required />
                        </div>

                    </div>

                    <div class="form-row">

                        <div class="form-col">
                            <label class="modal-label">Nombres *</label>
                            <input type="text" name="Nombres" class="modal-input" required />
                        </div>

                        <div class="form-col">
                            <label class="modal-label">Apellidos *</label>
                            <input type="text" name="Apellidos" class="modal-input" required />
                        </div>

                    </div>

                    <div class="form-row">

                        <div class="form-col">
                            <label class="modal-label">Correo electrónico</label>
                            <input type="email" name="Correo" class="modal-input" />
                        </div>

                        <div class="form-col">
                            <label class="modal-label">Teléfono</label>
                            <input type="text" name="Telefono" class="modal-input" />
                        </div>

                    </div>

                    <div class="form-row">

                        <div class="form-col">
                            <label class="modal-label">Estado</label>
                            <select name="Estado" class="modal-input modal-select">
                                <option value="Activo">Activo</option>
                                <option value="Inactivo">Inactivo</option>
                            </select>
                        </div>

                        <div class="form-col">
                            <label class="modal-label">Fecha de registro *</label>
                            <input type="date" name="FechaRegistro" class="modal-input" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                        </div>

                    </div>

                </div>

            </div>

            <div class="modal-footer-custom">
                <button type="button" class="btn btn-cancelar" id="btnCancelarModalCrear">Cancelar</button>
                <button type="submit" class="btn btn-guardar">Guardar alumno</button>
            </div>
        }

    </div>

</div>

<div class="modal-overlay" id="modalEliminarAlumno">

    <div class="modal-box" style="max-width:440px;">

        <div class="modal-header-custom">
            <h4>Eliminar Alumno</h4>
            <button type="button" class="btn-close-modal" id="btnCerrarModalEliminar">&times;</button>
        </div>

        <div class="modal-body-wrapper">
            <p style="margin:0; color:#334155; font-size:14px;">
                ¿Estás seguro de que deseas eliminar al alumno
                <strong id="lblNombreEliminar"></strong>
                (<span id="lblCodigoEliminar"></span>)?
                Esta acción no se puede deshacer.
            </p>
        </div>

        @using (Html.BeginForm("Delete", "Alumnoes", FormMethod.Post, new { id = "formEliminarAlumno" }))
        {
            @Html.AntiForgeryToken()

            <input type="hidden" id="modalIdEliminar" name="id" />

            <div class="modal-footer-custom">
                <button type="button" class="btn btn-cancelar" id="btnCancelarModalEliminar">Cancelar</button>
                <button type="submit" class="btn" style="background:#dc2626;border:1px solid #dc2626;color:white;border-radius:10px;padding:10px 18px;font-weight:500;">
                    Eliminar
                </button>
            </div>
        }

    </div>

</div>

<!-- Modal Editar Alumno -->
<div class="modal-overlay" id="modalEditarAlumno">

    <div class="modal-box">

        <div class="modal-header-custom">
            <h4>Editar Alumno</h4>
            <button type="button" class="btn-close-modal" id="btnCerrarModal">&times;</button>
        </div>

        @using (Html.BeginForm("Edit", "Alumnoes", FormMethod.Post, new { id = "formEditarAlumno" }))
        {
            @Html.AntiForgeryToken()

            <input type="hidden" id="modalIdAlumno" name="IdAlumno" />
            <input type="hidden" id="modalCodigoAlumno" name="CodigoAlumno" />
            <input type="hidden" id="modalFechaRegistro" name="FechaRegistro" />

            <div class="modal-body-wrapper">

                <div class="modal-body-grid">

                    <div class="form-row">

                        <div class="form-col">
                            <label class="modal-label">Nombres *</label>
                            <input type="text" id="modalNombres" name="Nombres" class="modal-input" required />
                        </div>

                        <div class="form-col">
                            <label class="modal-label">Apellidos *</label>
                            <input type="text" id="modalApellidos" name="Apellidos" class="modal-input" required />
                        </div>

                    </div>

                    <div class="form-row">

                        <div class="form-col">
                            <label class="modal-label">DNI *</label>
                            <input type="text" id="modalDNI" name="DNI" class="modal-input" required />
                        </div>

                        <div class="form-col">
                            <label class="modal-label">Teléfono</label>
                            <input type="text" id="modalTelefono" name="Telefono" class="modal-input" />
                        </div>

                    </div>

                    <div class="form-row form-row-single">

                        <div class="form-col">
                            <label class="modal-label">Correo electrónico</label>
                            <input type="email" id="modalCorreo" name="Correo" class="modal-input" />
                        </div>

                    </div>

                    <div class="form-row form-row-single">

                        <div class="form-col">
                            <label class="modal-label">Estado</label>
                            <select id="modalEstado" name="Estado" class="modal-input modal-select">
                                <option value="Activo">Activo</option>
                                <option value="Inactivo">Inactivo</option>
                            </select>
                        </div>

                    </div>

                </div>

            </div>

            <div class="modal-footer-custom">
                <button type="button" class="btn btn-cancelar" id="btnCancelarModal">Cancelar</button>
                <button type="submit" class="btn btn-guardar">Guardar cambios</button>
            </div>
        }

    </div>

</div>

<script>

    document.getElementById("txtBuscar")
        .addEventListener("keyup", function () {

            let filtro = this.value.toLowerCase();

            let filas =
                document.querySelectorAll("#tablaAlumnos tbody tr");

            let visibles = 0;

            filas.forEach(function (fila) {

                let texto =
                    fila.innerText.toLowerCase();

                let coincide = texto.includes(filtro);

                fila.style.display =
                    coincide
                        ? ""
                        : "none";

                if (coincide) {
                    visibles++;
                }

            });

            document.getElementById("lblResultados").innerText =
                visibles + " resultados";

        });


    var modalEditar = document.getElementById("modalEditarAlumno");

    function abrirModal() {
        modalEditar.classList.add("show");
    }

    function cerrarModal() {
        modalEditar.classList.remove("show");
    }

    document.getElementById("btnCerrarModal")
        .addEventListener("click", cerrarModal);

    document.getElementById("btnCancelarModal")
        .addEventListener("click", cerrarModal);

    modalEditar.addEventListener("click", function (e) {
        if (e.target === modalEditar) {
            cerrarModal();
        }
    });

    document.querySelectorAll(".btn-editar-alumno")
        .forEach(function (boton) {

            boton.addEventListener("click", function () {

                document.getElementById("modalIdAlumno").value = this.getAttribute("data-id");
                document.getElementById("modalCodigoAlumno").value = this.getAttribute("data-codigo");
                document.getElementById("modalFechaRegistro").value = this.getAttribute("data-fecharegistro");

                document.getElementById("modalNombres").value = this.getAttribute("data-nombres");
                document.getElementById("modalApellidos").value = this.getAttribute("data-apellidos");
                document.getElementById("modalDNI").value = this.getAttribute("data-dni");
                document.getElementById("modalTelefono").value = this.getAttribute("data-telefono");
                document.getElementById("modalCorreo").value = this.getAttribute("data-correo");
                document.getElementById("modalEstado").value = this.getAttribute("data-estado");

                abrirModal();

            });

        });

    var modalCrear = document.getElementById("modalCrearAlumno");

    function abrirModalCrear() {
        modalCrear.classList.add("show");
    }

    function cerrarModalCrear() {
        modalCrear.classList.remove("show");
    }

    document.getElementById("btnNuevoAlumno")
        .addEventListener("click", abrirModalCrear);

    document.getElementById("btnCerrarModalCrear")
        .addEventListener("click", cerrarModalCrear);

    document.getElementById("btnCancelarModalCrear")
        .addEventListener("click", cerrarModalCrear);

    modalCrear.addEventListener("click", function (e) {
        if (e.target === modalCrear) {
            cerrarModalCrear();
        }
    });


    var modalEliminar = document.getElementById("modalEliminarAlumno");

    function abrirModalEliminar() {
        modalEliminar.classList.add("show");
    }

    function cerrarModalEliminar() {
        modalEliminar.classList.remove("show");
    }

    document.getElementById("btnCerrarModalEliminar")
        .addEventListener("click", cerrarModalEliminar);

    document.getElementById("btnCancelarModalEliminar")
        .addEventListener("click", cerrarModalEliminar);

    modalEliminar.addEventListener("click", function (e) {
        if (e.target === modalEliminar) {
            cerrarModalEliminar();
        }
    });

    document.querySelectorAll(".btn-eliminar-alumno")
        .forEach(function (boton) {

            boton.addEventListener("click", function () {

                document.getElementById("modalIdEliminar").value = this.getAttribute("data-id");
                document.getElementById("lblNombreEliminar").innerText = this.getAttribute("data-nombrecompleto");
                document.getElementById("lblCodigoEliminar").innerText = this.getAttribute("data-codigo");

                abrirModalEliminar();

            });

        });

</script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
@if (TempData["Success"] != null)
{
    <script>
        Swal.fire({
            icon: 'success',
            title: 'Éxito',
            text: '@TempData["Success"]',
            confirmButtonColor: '#198754'
        });
    </script>
}

@if (TempData["Error"] != null)
{
    <script>
        Swal.fire({
            icon: 'error',
            title: 'Error',
            text: '@TempData["Error"]',
            confirmButtonColor: '#dc3545'
        });
    </script>
}