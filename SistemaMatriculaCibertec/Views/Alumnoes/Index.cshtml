@model IEnumerable<SistemaMatriculaCibertec.Models.Alumno>

@{
    ViewBag.Title = "Alumnos";
}

<style>

    body {
        background: #f4f7fb;
    }

    .page-container {
        padding: 20px;
    }

    .card-custom {
        background: white;
        border-radius: 18px;
        box-shadow: 0 3px 12px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .card-header-custom {
        padding: 25px;
        border-bottom: 1px solid #eef2f7;
    }

    .card-body-custom {
        padding: 20px;
    }

    .search-box {
        margin-bottom: 20px;
    }

        .search-box input {
            height: 48px;
            border-radius: 12px;
        }

    .table thead {
        background: #f8fafc;
    }

    .table th {
        border: none;
        color: #64748b;
        font-size: 13px;
        font-weight: 600;
    }

    .table td {
        vertical-align: middle;
    }

    .badge-success-custom {
        background: #d1fae5;
        color: #065f46;
        padding: 8px 15px;
        border-radius: 20px;
        font-size: 12px;
    }

    .btn-action {
        width: 36px;
        height: 36px;
        display: inline-flex;
        justify-content: center;
        align-items: center;
    }

    .pagination-custom {
        padding: 15px;
        display: flex;
        justify-content: flex-end;
        gap: 5px;
    }

        .pagination-custom a {
            width: 35px;
            height: 35px;
            border-radius: 8px;
            border: 1px solid #ddd;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            background: white;
            color: #333;
        }

        .pagination-custom .active {
            background: #2563eb;
            color: white;
            border-color: #2563eb;
        }
</style>

<div class="page-container">

    <div class="card-custom">

        <div class="card-header-custom">

            <div class="d-flex justify-content-between align-items-center">

                <div>

                    <h3 class="mb-1">
                        Alumnos Registrados
                    </h3>

                    <small class="text-muted">
                        @Model.Count() alumnos registrados
                    </small>

                </div>

                <a href="@Url.Action("Create")"
                   class="btn btn-primary">

                    Nuevo Alumno

                </a>

            </div>

        </div>

        <div class="card-body-custom">

            <div class="search-box">

                <input type="text"
                       id="txtBuscar"
                       class="form-control"
                       placeholder="Buscar alumno..." />

            </div>

            <div class="table-responsive">

                <table class="table table-hover"
                       id="tablaAlumnos">

                    <thead>

                        <tr>

                            <th>CÓDIGO</th>
                            <th>NOMBRES</th>
                            <th>APELLIDOS</th>
                            <th>DNI</th>
                            <th>CORREO</th>
                            <th>TELÉFONO</th>
                            <th>ESTADO</th>
                            <th>FECHA REGISTRO</th>
                            <th>ACCIONES</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    <strong class="text-primary">
                                        @item.CodigoAlumno
                                    </strong>
                                </td>

                                <td>@item.Nombres</td>

                                <td>@item.Apellidos</td>

                                <td>@item.DNI</td>

                                <td>@item.Correo</td>

                                <td>@item.Telefono</td>

                                <td>

                                    <span class="badge-success-custom">
                                        @item.Estado
                                    </span>

                                </td>

                                <td>

                                    @(item.FechaRegistro.ToString("dd/MM/yyyy"))

                                </td>

                                <td>

                                    <a href="@Url.Action("Edit", new { id = item.IdAlumno })"
                                       class="btn btn-primary btn-sm btn-action">

                                        <i class="bi bi-pencil"></i>

                                    </a>

                                    <a href="@Url.Action("Details", new { id = item.IdAlumno })"
                                       class="btn btn-info text-white btn-sm btn-action">

                                        <i class="bi bi-eye"></i>

                                    </a>

                                    <a href="@Url.Action("Delete", new { id = item.IdAlumno })"
                                       class="btn btn-danger btn-sm btn-action">

                                        <i class="bi bi-trash"></i>

                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

        <div class="pagination-custom">

            <a href="#">‹</a>

            <a href="#" class="active">1</a>

            <a href="#">›</a>

        </div>

    </div>

</div>

<script>

    document.getElementById("txtBuscar")
        .addEventListener("keyup", function () {

            let filtro = this.value.toLowerCase();

            let filas =
                document.querySelectorAll("#tablaAlumnos tbody tr");

            filas.forEach(function (fila) {

                let texto =
                    fila.innerText.toLowerCase();

                fila.style.display =
                    texto.includes(filtro)
                        ? ""
                        : "none";

            });

        });

</script>