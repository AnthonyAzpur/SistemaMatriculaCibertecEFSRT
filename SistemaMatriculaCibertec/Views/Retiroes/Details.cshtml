@model SistemaMatriculaCibertec.Models.Retiro

@{
    ViewBag.Title = "Detalle de Retiro";
}

<style>

    .page-container {
        padding: 20px;
    }

    .card-custom {
        background: white;
        border-radius: 18px;
        box-shadow: 0 3px 12px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .card-header-custom {
        padding: 25px;
        border-bottom: 1px solid #eef2f7;
    }

    .card-body-custom {
        padding: 25px;
    }

    .info-box {
        background: #f8fafc;
        border-radius: 12px;
        padding: 15px;
        margin-bottom: 15px;
    }

    .label-title {
        font-size: 13px;
        color: #64748b;
        margin-bottom: 5px;
    }

    .label-value {
        font-size: 16px;
        font-weight: 600;
    }
</style>

<div class="page-container">

    <div class="card-custom">

        <div class="card-header-custom">

            <h3 class="mb-1">
                Detalle de Retiro
            </h3>

            <small class="text-muted">
                Información completa del retiro
            </small>

        </div>

        <div class="card-body-custom">

            <div class="row">

                <div class="col-md-4">

                    <div class="info-box">

                        <div class="label-title">
                            Matrícula
                        </div>

                        <div class="label-value">

                            @Html.DisplayFor(model => model.Matricula.CodigoMatricula)

                        </div>

                    </div>

                </div>

                <div class="col-md-4">

                    <div class="info-box">

                        <div class="label-title">
                            Fecha de Retiro
                        </div>

                        <div class="label-value">

                            @Convert.ToDateTime(Model.FechaRetiro).ToString("dd/MM/yyyy")

                        </div>

                    </div>

                </div>

                <div class="col-md-4">

                    <div class="info-box">

                        <div class="label-title">
                            Motivo
                        </div>

                        <div class="label-value">

                            @Html.DisplayFor(model => model.Motivo)

                        </div>

                    </div>

                </div>

            </div>

            <hr />

            <a href="@Url.Action("Edit",
               new { id = Model.IdRetiro })"
               class="btn btn-primary">

                <i class="bi bi-pencil"></i>

                Editar

            </a>

            <a href="@Url.Action("Index")"
               class="btn btn-secondary">

                <i class="bi bi-arrow-left"></i>

                Volver

            </a>

        </div>

    </div>

</div>