@model IEnumerable<SistemaMatriculaCibertec.Models.Retiro>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.FechaRetiro)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Motivo)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Matricula.CodigoMatricula)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.FechaRetiro)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Motivo)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Matricula.CodigoMatricula)
        </td>
        <td>
            @Html.ActionLink("Edit", "Edit", new { id=item.IdRetiro }) |
            @Html.ActionLink("Details", "Details", new { id=item.IdRetiro }) |
            @Html.ActionLink("Delete", "Delete", new { id=item.IdRetiro })
        </td>
    </tr>
}

</table>
