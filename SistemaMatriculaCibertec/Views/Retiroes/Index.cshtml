@model IEnumerable<SistemaMatriculaCibertec.Models.Retiro>

@{
    ViewBag.Title = "Retiros";
}

<style>

    body {
        background: #f4f7fb;
    }

    .page-container {
        padding: 20px;
    }

    .card-custom {
        background: white;
        border-radius: 18px;
        box-shadow: 0 3px 12px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .card-header-custom {
        padding: 25px;
        background: white;
        border-bottom: 1px solid #eef2f7;
    }

    .card-body-custom {
        padding: 20px;
    }

    .search-box {
        margin-bottom: 20px;
    }

        .search-box input {
            border-radius: 12px;
            height: 48px;
        }

    .table {
        margin-bottom: 0;
    }

        .table thead {
            background: #f8fafc;
        }

        .table th {
            color: #64748b;
            font-size: 13px;
            font-weight: 600;
            border: none;
        }

        .table td {
            vertical-align: middle;
        }

    .badge-success-custom {
        background: #d1fae5;
        color: #065f46;
        padding: 8px 15px;
        border-radius: 20px;
        font-size: 12px;
    }

    .btn-action {
        width: 36px;
        height: 36px;
        display: inline-flex;
        justify-content: center;
        align-items: center;
    }

    .pagination-custom {
        padding: 15px;
        display: flex;
        justify-content: flex-end;
        gap: 5px;
    }

        .pagination-custom a {
            width: 35px;
            height: 35px;
            border-radius: 8px;
            border: 1px solid #ddd;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            background: white;
            color: #333;
        }

        .pagination-custom .active {
            background: #2563eb;
            color: white;
            border-color: #2563eb;
        }
</style>



<div class="page-container">

    <div class="card-custom">

        <div class="card-header-custom">

            <div class="d-flex justify-content-between align-items-center">

                <div>

                    <h3 class="mb-1">
                        Retiros Registrados
                    </h3>

                    <small class="text-muted">
                        @Model.Count() retiros registrados
                    </small>

                </div>

                <a href="@Url.Action("Create")"
                   class="btn btn-danger">

                    <i class="bi bi-plus-circle"></i>

                    Nuevo Retiro

                </a>

            </div>

        </div>



        <div class="card-body-custom">

            <div class="search-box">

                <input type="text"
                       id="txtBuscar"
                       class="form-control"
                       placeholder="Buscar retiro..." />

            </div>



            <div class="table-responsive">

                <table class="table table-hover"
                       id="tablaRetiros">

                    <thead>

                        <tr>

                            <th>CÓDIGO RETIRO</th>

                            <th>MATRÍCULA</th>

                            <th>FECHA RETIRO</th>

                            <th>MOTIVO</th>

                            <th>ESTADO</th>

                            <th>ACCIONES</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {

                            <tr>

                                <td>

                                    <span class="text-danger fw-bold">

                                        @item.CodigoRetiro

                                    </span>

                                </td>

                                <td>

                                    <strong>

                                        @item.Matricula.CodigoMatricula

                                    </strong>

                                </td>

                                <td>

                                    @Convert.ToDateTime(item.FechaRetiro).ToString("dd/MM/yyyy")

                                </td>

                                <td>

                                    @item.Motivo

                                </td>

                                <td>

                                    <span class="badge-success-custom">

                                        Procesado

                                    </span>

                                </td>

                                <td>

                                    <a href="@Url.Action("Edit",
                                    new { id = item.IdRetiro })"
                                       class="btn btn-primary btn-sm btn-action">

                                        <i class="bi bi-pencil"></i>

                                    </a>


                                    <a href="@Url.Action("Details",
                                    new { id = item.IdRetiro })"
                                       class="btn btn-info text-white btn-sm btn-action">

                                        <i class="bi bi-eye"></i>

                                    </a>


                                    <a href="@Url.Action("Delete",
                                    new { id = item.IdRetiro })"
                                       class="btn btn-danger btn-sm btn-action">

                                        <i class="bi bi-trash"></i>

                                    </a>

                                </td>

                            </tr>

                        }

                    </tbody>

                </table>

            </div>

        </div>



        <div class="pagination-custom">

            <a href="#">‹</a>

            <a href="#" class="active">1</a>

            <a href="#">›</a>

        </div>

    </div>

</div>


<script>

    document.getElementById("txtBuscar")
        .addEventListener("keyup", function () {

            let filtro =
                this.value.toLowerCase();

            let filas =
                document.querySelectorAll("#tablaRetiros tbody tr");

            filas.forEach(function (fila) {

                let texto =
                    fila.innerText.toLowerCase();

                fila.style.display =
                    texto.includes(filtro)
                        ? ""
                        : "none";

            });

        });

</script>