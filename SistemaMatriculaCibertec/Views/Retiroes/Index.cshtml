@model IEnumerable<SistemaMatriculaCibertec.Models.Retiro>

@{
    ViewBag.Title = "Retiros";
}




<div class="page-container">

    <div class="card-custom">

        <div class="card-header-custom">

            <div class="d-flex justify-content-between align-items-center">

                <div>

                    <h3 class="mb-1">
                        Retiros Registrados
                    </h3>

                    <small class="text-muted">
                        @Model.Count() retiros registrados
                    </small>

                </div>

                <a href="@Url.Action("Create")"
                   class="btn btn-danger">

                    <i class="bi bi-plus-circle"></i>

                    Nuevo Retiro

                </a>

            </div>

        </div>



        <div class="card-body-custom">

            <div class="search-box">

                <input type="text"
                       id="txtBuscar"
                       class="form-control"
                       placeholder="Buscar retiro..." />

            </div>



            <div class="table-responsive">

                <table class="table table-hover"
                       id="tablaRetiros">

                    <thead>

                        <tr>

                            <th>CÓDIGO RETIRO</th>

                            <th>MATRÍCULA</th>

                            <th>FECHA RETIRO</th>

                            <th>MOTIVO</th>

                            <th>ESTADO</th>

                            <th>ACCIONES</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {

                            <tr>

                                <td>

                                    <span class="text-danger fw-bold">

                                        @item.CodigoRetiro

                                    </span>

                                </td>

                                <td>

                                    <strong>

                                        @item.Matricula.CodigoMatricula

                                    </strong>

                                </td>

                                <td>

                                    @Convert.ToDateTime(item.FechaRetiro).ToString("dd/MM/yyyy")

                                </td>

                                <td>

                                    @item.Motivo

                                </td>

                                <td>

                                    <span class="badge-success-custom">

                                        Procesado

                                    </span>

                                </td>

                                <td>

                                    <a href="@Url.Action("Edit",
                                    new { id = item.IdRetiro })"
                                       class="btn btn-primary btn-sm btn-action">

                                        <i class="bi bi-pencil"></i>

                                    </a>


                                    <a href="@Url.Action("Details",
                                    new { id = item.IdRetiro })"
                                       class="btn btn-info text-white btn-sm btn-action">

                                        <i class="bi bi-eye"></i>

                                    </a>


                                    <a href="@Url.Action("Delete",
                                    new { id = item.IdRetiro })"
                                       class="btn btn-danger btn-sm btn-action">

                                        <i class="bi bi-trash"></i>

                                    </a>

                                </td>

                            </tr>

                        }

                    </tbody>

                </table>

            </div>

        </div>



        <div class="pagination-custom">

            <a href="#">‹</a>

            <a href="#" class="active">1</a>

            <a href="#">›</a>

        </div>

    </div>

</div>


<script>

    document.getElementById("txtBuscar")
        .addEventListener("keyup", function () {

            let filtro =
                this.value.toLowerCase();

            let filas =
                document.querySelectorAll("#tablaRetiros tbody tr");

            filas.forEach(function (fila) {

                let texto =
                    fila.innerText.toLowerCase();

                fila.style.display =
                    texto.includes(filtro)
                        ? ""
                        : "none";

            });

        });

</script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
@if (TempData["Success"] != null)
{
    <script>
        Swal.fire({
            icon: 'success',
            title: 'Éxito',
            text: '@TempData["Success"]',
            confirmButtonColor: '#198754'
        });
    </script>
}

@if (TempData["Error"] != null)
{
    <script>
        Swal.fire({
            icon: 'error',
            title: 'Error',
            text: '@TempData["Error"]',
            confirmButtonColor: '#dc3545'
        });
    </script>
}