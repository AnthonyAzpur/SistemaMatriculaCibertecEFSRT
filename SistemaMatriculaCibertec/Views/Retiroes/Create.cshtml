@model SistemaMatriculaCibertec.Models.Retiro

@{
    ViewBag.Title = "Nuevo Retiro";
}

<style>

    .page-container {
        padding: 20px;
    }

    .card-custom {
        background: white;
        border-radius: 18px;
        box-shadow: 0 3px 12px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .card-header-custom {
        padding: 25px;
        border-bottom: 1px solid #eef2f7;
    }

    .card-body-custom {
        padding: 25px;
    }

    .form-control {
        border-radius: 10px;
        height: 45px;
    }

    textarea.form-control {
        height: 100px;
    }

    .btn-guardar {
        min-width: 140px;
    }
</style>

<div class="page-container">

    <div class="card-custom">

        <div class="card-header-custom">

            <h3 class="mb-1">
                Nuevo Retiro
            </h3>

            <small class="text-muted">
                Registrar retiro de matrícula
            </small>

        </div>

        <div class="card-body-custom">

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label>
                            Matrícula
                        </label>

                        @Html.DropDownList(
                            "IdMatricula",
                            null,
                            "-- Seleccione una matrícula --",
                            new { @class = "form-control" }
                        )

                        @Html.ValidationMessageFor(
                            model => model.IdMatricula,
                            "",
                            new { @class = "text-danger" }
                        )

                    </div>

                    <div class="col-md-6 mb-3">

                        <label>
                            Fecha de Retiro
                        </label>

                        @Html.EditorFor(
                            model => model.FechaRetiro,
                            new
                            {
                                htmlAttributes = new
                                {
                                    @class = "form-control",
                                    type = "date"
                                }
                            })

                        @Html.ValidationMessageFor(
                            model => model.FechaRetiro,
                            "",
                            new { @class = "text-danger" }
                        )

                    </div>

                </div>

                <div class="mb-3">

                    <label>
                        Motivo del Retiro
                    </label>

                    @Html.TextAreaFor(
                        model => model.Motivo,
                        new
                        {
                            @class = "form-control",
                            rows = "4",
                            placeholder = "Ingrese el motivo del retiro"
                        })

                    @Html.ValidationMessageFor(
                        model => model.Motivo,
                        "",
                        new { @class = "text-danger" }
                    )

                </div>

                <hr />

                <div class="d-flex gap-2">

                    <button type="submit"
                            class="btn btn-danger btn-guardar">

                        <i class="bi bi-save"></i>

                        Guardar

                    </button>

                    <a href="@Url.Action("Index")"
                       class="btn btn-secondary">

                        <i class="bi bi-arrow-left"></i>

                        Volver

                    </a>

                </div>

            }

        </div>

    </div>

</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}